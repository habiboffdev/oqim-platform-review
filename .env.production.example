# OQIM Business — Production Environment Variables
# Copy to .env.production and fill in all values
# cp .env.production.example .env.production

# ─── App ────────────────────────────────────────────────
APP_ENV=production
# Generate: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ─── Domain (used by setup script) ─────────────────────
DOMAIN=your-domain.com

# ─── Database ───────────────────────────────────────────
# Generate a strong password: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
# Note: DATABASE_URL is set in docker-compose.prod.yml using POSTGRES_PASSWORD
# You do NOT need to set DATABASE_URL here

# ─── Telegram ──────────────────────────────────────────
# Get from https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Generate: python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
TELEGRAM_SESSION_KEY=CHANGE_ME_GENERATE_FERNET_KEY

# ─── AI / Gemini ───────────────────────────────────────
# Option A: Direct Gemini Developer API key (local fallback only)
GEMINI_API_KEY=

# Option B: Vertex AI (recommended for production)
# Set GOOGLE_GENAI_USE_VERTEXAI=true so Vertex/ADC wins even if GEMINI_API_KEY is present.
# Requires service account JSON at /etc/google/credentials.json or VM/workload ADC.
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
# DISCOVERY_ENGINE_RANKING_LOCATION=global
# DISCOVERY_ENGINE_RANKING_CONFIG=default_ranking_config
# DISCOVERY_ENGINE_RANKING_MODEL=semantic-ranker-default-v1
# GOOGLE_AUTH_SOURCE=service_account
# GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=
# GOOGLE_APPLICATION_CREDENTIALS=/etc/google/credentials.json

# AI model overrides (optional — defaults are fine)
# PRE_PASS_MODEL=gemini-3.1-flash-lite-preview
# AGENT_MODEL=gemini-3-flash-preview
# Estimated founder spend policy, in micros of USD per 1K tokens.
# LLM_USAGE_COST_MICROS_PER_1K_TOKENS=gemini:input:300,gemini:output:2500,vertex:input:300,vertex:output:2500,cerebras:input:600,cerebras:output:1200
# Optional daily estimated LLM spend guard per workspace. 0 disables blocking.
# LLM_DAILY_COST_BUDGET_MICROS_PER_WORKSPACE=0

# ─── Groq (optional fallback LLM) ─────────────────────
GROQ_API_KEY=

# ─── GramJS Sidecar ────────────────────────────────────
# Generate: openssl rand -hex 16
SIDECAR_API_KEY=CHANGE_ME_GENERATE_API_KEY
SIDECAR_URL=http://gramjs-sidecar:3100

# ─── CORS ──────────────────────────────────────────────
# Set to your production domain (with https://)
CORS_ORIGINS=https://your-domain.com

# ─── Cookies ───────────────────────────────────────────
COOKIE_DOMAIN=your-domain.com
COOKIE_SECURE=true

# ─── Runtime Migration Flags ───────────────────────────
EVENT_SPINE_PERSIST_CONSUMER_ENABLED=true
EVENT_SPINE_PERSIST_MODE=authoritative
CONVERSATION_READ_REPAIR_ENABLED=false
LEGACY_RUNTIME_ROUTES_ENABLED=false
REPLY_AUTOPILOT_ENABLED=false
SCHEDULED_REPLY_SENDER_ENABLED=false

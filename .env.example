# ══════════════════════════════════════════════════
# OQIM Business — Environment Configuration
# ══════════════════════════════════════════════════
# Copy to .env and fill in values.
# REQUIRED fields are marked. Others have sane defaults.

# ── Environment ──
APP_ENV=development  # development | staging | production

# ── Database (REQUIRED) ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5434/oqim_business
# NOTE: POSTGRES_PASSWORD must be alphanumeric — +, /, @ break asyncpg URL parsing

# ── Redis ──
REDIS_URL=redis://localhost:6381/0

# ── Security (REQUIRED in production) ──
SECRET_KEY=dev-only-insecure-key-not-for-production  # openssl rand -hex 32
TELEGRAM_SESSION_KEY=  # python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'

# ── Cookies (REQUIRED in production) ──
COOKIE_DOMAIN=  # e.g., your-domain.example
COOKIE_SECURE=false  # true in production

# ── CORS ──
CORS_ORIGINS=http://business.localhost,http://localhost:4200,http://localhost:3001

# ── AI / LLM (REQUIRED — at least one auth path) ──
GEMINI_API_KEY=
CEREBRAS_API_KEY=

# ── Google Cloud / Vertex AI (recommended for Gemini in production) ──
# Local dev: run `gcloud auth application-default login`, then set this true.
# If true, Vertex AI + ADC wins even when a stale GEMINI_API_KEY is present.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
DISCOVERY_ENGINE_RANKING_LOCATION=global
DISCOVERY_ENGINE_RANKING_CONFIG=default_ranking_config
DISCOVERY_ENGINE_RANKING_MODEL=semantic-ranker-default-v1
GOOGLE_AUTH_SOURCE=auto  # auto | adc | service_account
GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=  # optional: service-account@project.iam.gserviceaccount.com
GOOGLE_APPLICATION_CREDENTIALS=  # path to service account JSON, e.g. deploy/gcp-service-account.json

# ── Telegram / GramJS sidecar (REQUIRED for connection) ──
TELEGRAM_API_ID=   # get from https://my.telegram.org/apps
TELEGRAM_API_HASH=  # get from https://my.telegram.org/apps
SIDECAR_URL=http://localhost:3100
SIDECAR_API_KEY=dev-sidecar-key  # openssl rand -hex 32 in production

# ── AI Model Overrides (optional) ──
PRE_PASS_MODEL=gemini-3.1-flash-lite-preview
AGENT_MODEL=gemini-3-flash-preview
# Estimated founder spend policy, in micros of USD per 1K tokens.
LLM_USAGE_COST_MICROS_PER_1K_TOKENS=gemini:input:300,gemini:output:2500,vertex:input:300,vertex:output:2500,cerebras:input:600,cerebras:output:1200
# Optional daily estimated LLM spend guard per workspace. 0 disables blocking.
LLM_DAILY_COST_BUDGET_MICROS_PER_WORKSPACE=0
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_DEFAULT_MODEL=qwen-3-235b-a22b-instruct-2507
CEREBRAS_TIMEOUT=5.0

# ── Rollback Safety (optional) ──
ROLLBACK_HALLUCINATION_RATE_THRESHOLD=0.03
ROLLBACK_COMPLAINT_RATE_THRESHOLD=0.05
ROLLBACK_DELIVERY_FAILURE_RATE_THRESHOLD=0.02
ROLLBACK_SEVERE_INCORRECT_FACT_LEVELS=major,critical

# ── Media ──
MEDIA_DIR=./media

# ── Runtime Migration Flags ──
EVENT_SPINE_PERSIST_CONSUMER_ENABLED=true
EVENT_SPINE_PERSIST_MODE=authoritative
CONVERSATION_READ_REPAIR_ENABLED=false
LEGACY_RUNTIME_ROUTES_ENABLED=false
AUTOCRM_EXTRACTION_RUNTIME_ENABLED=true
REPLY_AUTOPILOT_ENABLED=false
SCHEDULED_REPLY_SENDER_ENABLED=false
